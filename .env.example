# Hackathon shared .env schema. Copy to .env at the hackathon/ level if you
# want shared secrets across teams (uncommon — most teams maintain their own
# .env inside submissions/team_<name>/). .env is gitignored at every level.

# -- Slack ----------------------------------------------------------------
# Most teams will create their own Slack app for development. Put the bot's
# tokens in submissions/team_<name>/.env, not here.
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# -- Local LLM via Ollama -------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# -- Remote LLM (optional fallbacks) --------------------------------------
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# -- Web search (optional) ------------------------------------------------
# TAVILY_API_KEY=

# -- Lab-wide storage roots -----------------------------------------------
LAB_AI_DATA_DIR=./data
LAB_AI_LOG_DIR=./logs
